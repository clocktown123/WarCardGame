
public class GroupOfCards {
    protected Card[] cards;
    protected int currentSize;

    public GroupOfCards(int capacity) {
        cards = new Card[capacity];
        currentSize = 0;
    }

    public int size() {
        return currentSize;
    }

    public void addCard(Card card) {
        if (currentSize >= cards.length) {
            throw new IllegalStateException("GroupOfCards is full.");
        }
        cards[currentSize] = card;
        currentSize++;
    }



    public void addCardBottom(Card card) {
        if (currentSize >= cards.length) {
            throw new IllegalStateException("GroupOfCards is full.");
        }
        for (int i = currentSize; i > 0; i--){
            cards[i] = cards[i - 1];
        }
        cards[0] = card;
        currentSize++;
    }

    // Polymorphism target: subclasses should override display()
    public void display() {
        for (int i = 0; i < currentSize; i++) {
            System.out.print(cards[i]);
            if (i < currentSize - 1) System.out.print(", ");
        }
        System.out.println();
    }
}
