import java.util.Scanner;

public class Game {
    Scanner stdIn = new Scanner(System.in);
    String choice;

    private Deck deck;
    private Hand player1;
    private Hand player2;

    public Game() {
        deck = new Deck();
        player1 = new Hand(52);
        player2 = new Hand(52);
    }

    public void playAGame() {
        deck.shuffle();

        // Deal 26 cards each
        for (int i = 0; i < 26; i++) {
            player1.addCard(deck.dealCard());
            player2.addCard(deck.dealCard());
        }

        while(player1.size() > 0 && player2.size() > 0) {

            // Polymorphism: treat different subclasses as GroupOfCards
            GroupOfCards[] groups = {deck, player1, player2};
            for (GroupOfCards g : groups) {
                g.display();
            }

            Card c1 = player1.playACard();
            Card c2 = player2.playACard();

            System.out.println("\nPlayer 1 plays: " + c1);
            System.out.println("Player 2 plays: " + c2);

            if (c1.num > c2.num) {
                System.out.println("Player 1 wins the round!");
                player1.addCardBottom(c1);
                player1.addCardBottom(c2);

                System.out.printf("Player 1 has taken the card %s from Player 2%n", c2);
            } else if (c2.num > c1.num) {
                System.out.println("Player 2 wins the round!");
                player2.addCardBottom(c2);
                player2.addCardBottom(c1);
                System.out.printf("Player 2 has taken the card %s from player 1%n", c1);
            } else {
                System.out.println("This means war!");
                player1.war(player2, c1, c2);

            }

            System.out.print("press anything to play another hand");
            choice = stdIn.next();

        }
    }

}
