public class Hand extends GroupOfCards {

    public Hand(int capacity) {
        super(capacity);
    }

    public Card playACard() {
        if (currentSize == 0) return null;
        Card c = cards[currentSize - 1];
        cards[currentSize - 1] = null;
        currentSize--;
        return c;
    }

    //Here is a recursive method for war
    public void war(Hand hand, Card card1, Card card2){
        Card temp1 = playACard();
        Card temp2 = hand.playACard();

        System.out.println("\nPlayer 1 plays: " + temp1);
        System.out.println("Player 2 plays: " + temp2);

        if (temp1.num > temp2.num) {
            System.out.println("Player 1 wins the round!");
            addCardBottom(card1);
            addCardBottom(card2);
            addCardBottom(temp1);
            addCardBottom(temp2);


            System.out.printf("Player 1 has taken the cards %s and %s from Player 2%n", card2, temp2);
        } else if (temp2.num > temp1.num) {
            System.out.println("Player 2 wins the round!");
            hand.addCardBottom(card2);
            hand.addCardBottom(card1);
            hand.addCardBottom(temp2);
            hand.addCardBottom(temp1);

            System.out.printf("Player 2 has taken the cards %s and %s from Player 1%n", card1, temp1);
        }
        else{
            System.out.println("This means war!");
            war(hand, temp1, temp2);
        }
    }

    //Here is the overriden method
    @Override
    public void display() {
        System.out.print("Hand (" + currentSize + "): ");
        super.display();
    }
}
